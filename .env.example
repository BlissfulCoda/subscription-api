# Optional: set NODE_ENV here so plain `tsx index.ts` picks the right file
# before `.env.<development|production>.local` loads.
# NODE_ENV=production

# Use:
#   .env.development.local  or  .env.production.local
# Or rely on package.json: `pnpm dev` / `pnpm start` (sets NODE_ENV for you).

# Neon (see https://neon.com/docs/guides/prisma):
#   DATABASE_URL = pooled connection (…-pooler… host) — app + PrismaClient
#   DIRECT_URL   = direct connection (no pooler) — `prisma migrate` / `db push`
